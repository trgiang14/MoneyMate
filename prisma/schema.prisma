// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  password      String?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  transactions  Transaction[]
  categories    Category[]
  budgets       Budget[]
  savingGoals   SavingGoal[]
  recurringTransactions RecurringTransaction[]
  reminders     Reminder[]
  bills         Bill[]
}

model Category {
  id            String    @id @default(cuid())
  name          String
  type          CategoryType
  icon          String?
  color         String?
  userId        String?
  user          User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions  Transaction[]
  recurringTransactions RecurringTransaction[]
  budgets       Budget[]
  bills         Bill[]
  isDefault     Boolean   @default(false)

  @@index([userId])
}

enum CategoryType {
  INCOME
  EXPENSE
}

model Transaction {
  id            String    @id @default(cuid())
  amount        Float
  description   String?
  date          DateTime  @default(now())
  type          CategoryType
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId    String
  category      Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  
  // Link to recurring transaction if this was generated automatically
  recurringTransactionId String?
  recurringTransaction   RecurringTransaction? @relation(fields: [recurringTransactionId], references: [id], onDelete: SetNull)

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([userId])
  @@index([categoryId])
  @@index([recurringTransactionId])
}

model RecurringTransaction {
  id            String    @id @default(cuid())
  amount        Float
  description   String?
  type          CategoryType
  
  // Recurrence pattern
  frequency     RecurrenceFrequency
  startDate     DateTime
  endDate       DateTime?
  lastRunDate   DateTime?
  nextRunDate   DateTime

  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId    String
  category      Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  
  transactions  Transaction[]

  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([userId])
  @@index([categoryId])
  @@index([nextRunDate])
}

model Reminder {
  id            String    @id @default(cuid())
  title         String
  description   String?
  time          String    // Định dạng "HH:mm"
  daysOfWeek    String    // Lưu dưới dạng chuỗi "1,2,3,4,5,6,0" (0 là Chủ Nhật)
  isActive      Boolean   @default(true)
  
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([userId])
}

model Bill {
  id            String    @id @default(cuid())
  name          String
  amount        Float
  dueDate       Int       // Ngày trong tháng (1-31)
  description   String?
  isActive      Boolean   @default(true)
  
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId    String
  category      Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([userId])
  @@index([categoryId])
}

enum RecurrenceFrequency {
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}

model Budget {
  id          String   @id @default(cuid())
  amount      Float
  month       Int      // 1-12
  year        Int
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, categoryId, month, year])
  @@index([userId])
}

model SavingGoal {
  id            String   @id @default(cuid())
  name          String
  targetAmount  Float
  currentAmount Float    @default(0)
  deadline      DateTime?
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
}
